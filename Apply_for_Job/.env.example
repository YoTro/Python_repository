# ── LLM Provider for HR Chat ──────────────────────────────────────────
# Supported: anthropic / openai / gemini / deepseek
HRC_PROVIDER=anthropic

# Model override (leave blank to use the provider default)
#   Anthropic default : claude-haiku-4-5-20251001
#   OpenAI default    : gpt-4o-mini
#   Gemini default    : gemini-1.5-flash
#   DeepSeek default  : deepseek-chat  (maps to DeepSeek-V3 latest)
HRC_MODEL=

# Max questions per job (default 6)
HRC_MAX_TURNS=6

# ── API Keys (fill in the one matching your provider) ─────────────────
ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...
# GEMINI_API_KEY=AIza...
# DEEPSEEK_API_KEY=sk-...
