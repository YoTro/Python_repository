# ── Python ────────────────────────────────────────────────────────────
__pycache__/
*.pyc
*.pyo
*.pyd
*.db
*.sqlite3
.pytest_cache/
.coverage
coverage.xml
htmlcov/
.venv/
venv/
venv*/
ENV/
*.egg-info/
dist/
build/

# ── Node.js ───────────────────────────────────────────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
package-lock.json

# ── macOS ─────────────────────────────────────────────────────────────
.DS_Store
.AppleDouble
.LSOverride

# ── IDEs ──────────────────────────────────────────────────────────────
.idea/
.vscode/
*.swp
*.swo

# ── Logs ──────────────────────────────────────────────────────────────
logs/
*.log

# ── Data (scraped / generated — never commit raw data) ────────────────
data/raw/
data/processed/
data/reports/
!data/raw/.gitkeep
!data/processed/.gitkeep
!data/reports/.gitkeep

# ── Chart images (generated by report.py) ─────────────────────────────
*.png
!src/job51/nc_env/data/*.png

# ── WAF / NC challenge runtime data ───────────────────────────────────
src/job51/nc_env/data/*.json
src/job51/nc_env/data/*.html
src/job51/nc_env/data/*.png
!src/job51/nc_env/data/.gitkeep

# ── Credentials & environment ─────────────────────────────────────────
.env
.env.local
.env.*.local
config/amapkey.json

# ── Chat bot training / session data ──────────────────────────────────
data/training/
*.jsonl

# ── Candidate profile ─────────────────────────────────────────────────
