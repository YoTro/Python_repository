  "tier_type_legend": {
    "flat":        "Single rate applies to the entire total sales price",
    "whole_price": "The total sales price determines which single rate applies to the ENTIRE amount",
    "proportional":"Each portion of the price is charged at its own bracket rate; amounts are summed (like income tax brackets)"
  },
  "calculation_rules": {
    "description": "How Amazon calculates the referral fee for each order",
    "steps": [
      "1. Determine total sales price = item price + shipping charges + gift wrap charges (excluding Amazon-collected tax)",
      "2. Identify the category's tier_type: flat / whole_price / proportional",
      "3. Apply the rate(s) according to tier_type",
      "4. Compare the result with the per-item minimum referral fee",
      "5. Amazon deducts whichever amount is GREATER: the calculated fee OR the minimum fee"
    ],
    "examples": [
      {
        "scenario": "Proportional – Jewelry at $400",
        "calculation": "20% × $250 + 5% × ($400 - $250) = $50.00 + $7.50 = $57.50",
        "final_fee_usd": 57.50
      },
      {
        "scenario": "Whole-price – Baby Product at $8",
        "calculation": "8% × $8 = $0.64 (price ≤ $10, so 8% applies to the whole amount)",
        "final_fee_usd": 0.64
      },
      {
        "scenario": "Whole-price – Baby Product at $25",
        "calculation": "15% × $25 = $3.75 (price > $10, so 15% applies to the whole amount)",
        "final_fee_usd": 3.75
      },
      {
        "scenario": "Minimum fee trigger – Home and Kitchen at $1.50",
        "calculation": "15% × $1.50 = $0.225; minimum fee $0.30 > $0.225 → minimum applies",
        "final_fee_usd": 0.30
      }
    ]
  },
