    "long_context_gt200k": {
      "type": "tier_switch",
      "threshold_input_tokens": 200000,
      "applies_to_model_ids": [
        "claude-sonnet-4-5",
        "claude-sonnet-4-0"
      ],
      "lookup_keys": [
        "{model_id}#long_context_gt200k#input",
        "{model_id}#long_context_gt200k#output"
      ],
      "threshold_calculation": "sum(input_tokens + cache_creation_input_tokens + cache_read_input_tokens) > 200000",
