  "modifiers": {
    "prompt_caching": {
      "type": "multiplier_on_base_input",
      "base_ref": "lookup['{model_id}#standard#input'].price",
      "variants": {
        "cache_write_5m": {
          "lookup_key": "{model_id}#standard#cache_write_5m",
          "factor": 1.25,
          "ttl_minutes": 5,
          "break_even_reads": 1
        },
        "cache_write_1h": {
          "lookup_key": "{model_id}#standard#cache_write_1h",
          "factor": 2.0,
          "ttl_minutes": 60,
          "break_even_reads": 2
        },
        "cache_read": {
          "lookup_key": "{model_id}#standard#cache_read",
          "factor": 0.1,
          "savings_pct": 90
        }
      },
      "api_response_fields": {
        "cache_write": "cache_creation_input_tokens",
        "cache_read": "cache_read_input_tokens"
      },
      "ttl_selection_note": "API does not return TTL in response. Select cache_write_5m or cache_write_1h based on your cache_control config. Default to cache_write_5m if unknown.",
      "stacks_with": [
        "batch",
        "long_context_gt200k",
        "data_residency_us",
        "fast_mode"
      ],
      "not_available_with": []
    },
    "batch": {
      "type": "multiplier_on_standard",
      "factor": 0.5,
      "base_ref": "lookup['{model_id}#standard#input|output'].price",
      "lookup_keys": [
        "{model_id}#batch#input",
        "{model_id}#batch#output"
      ],
      "stacks_with": [
        "prompt_caching",
        "long_context_gt200k"
      ],
      "not_available_with": [
        "fast_mode"
      ],
      "precedence_note": "NOT_AVAILABLE_WITH > STACKS_WITH"
    },
    "data_residency_us": {
      "type": "multiplier",
      "factor": 1.1,
      "activation": "inference_geo=US",
      "applies_to_dimensions": [
        "input",
        "output",
        "cache_write_5m",
        "cache_write_1h",
        "cache_read"
      ],
      "applies_to_model_ids": [
        "claude-opus-4-6",
        "claude-sonnet-4-6",
        "claude-opus-4-5",
        "claude-sonnet-4-5",
        "claude-haiku-4-5",
        "claude-opus-4-1",
        "claude-opus-4-0",
        "claude-sonnet-4-0",
        "claude-haiku-3-5"
      ],
      "applies_to_future_models": true,
      "stacks_with": [
        "batch",
        "prompt_caching",
        "fast_mode",
        "long_context_gt200k"
      ],
      "not_available_with": [],
      "application_order": "applied_last_after_all_other_modifiers"
    },
    "fast_mode": {
      "type": "multiplier_on_standard",
      "factor": 6.0,
      "applies_to_model_ids": [
        "claude-opus-4-6"
      ],
      "lookup_keys": [
        "claude-opus-4-6#fast_mode#input",
        "claude-opus-4-6#fast_mode#output"
      ],
      "stacks_with": [
        "prompt_caching",
        "data_residency_us"
      ],
      "not_available_with": [
        "batch"
      ],
      "precedence_note": "NOT_AVAILABLE_WITH > STACKS_WITH",
      "availability": "research_preview"
