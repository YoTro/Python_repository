    "conventions": {
      "price_entry_shape": {
        "price": "number (USD)",
        "unit": "always 'USD'",
        "billing_unit": "per_1M_tokens",
        "dimension": "input | input_cache_hit | output"
      },
      "lookup_key_pattern": "{canonical_model_id}#{tier}#{dimension}",
      "tier_values": "standard | batch",
      "resolution_flow": "any_string -> model_string_index -> canonical_id -> lookup key",
      "cache_note": "Cached input (automatic prompt caching) billed at input_cache_hit price; non-cached input at input price. Reasoning/'pro' models do not expose a cached-input rate — cached tokens fall back to the full input price in PriceManager.",
      "batch_note": "Batch API (async) is a uniform 50% discount on input, cached input, and output. Batch entries are derived as standard x 0.5.",
      "gpt_5_5_pro_batch_note": "Source page returned an anomalous batch rate for gpt-5.5-pro (higher than standard); corrected to the standard 50% discount, matching its sibling gpt-5.4-pro.",
      "coverage_note": "Only the GPT-5.x generation (plus chatgpt-latest and gpt-5.3-codex) is listed on the developer pricing page. Earlier families (gpt-4.1, gpt-4o, o3, o4-mini) were not present and are intentionally omitted."
    }
  },
